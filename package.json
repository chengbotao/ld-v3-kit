{
  "private": true,
  "packageManager": "pnpm@10.14.0",
  "workspaces": [
    "packages/*",
    "docs"
  ],
  "scripts": {
    "build": "pnpm clean && jiti scripts/rolldown-build.ts",
    "clean": "rimraf dist",
    "docs:dev": "pnpm --filter docs dev",
    "docs:build": "pnpm --filter docs build",
    "docs:preview": "pnpm --filter docs preview",
    "commit": "git-cz",
    "lint:fix": "eslint --fix",
    "lint:staged": "lint-staged",
    "lint:style:fix": "stylelint '**/*.{css,scss,vue}' --fix --allow-empty-input",
    "preinstall": "npx only-allow pnpm",
    "prepublishOnly": "pnpm build",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@commitlint/cz-commitlint": "^21.0.1",
    "@eslint/js": "^10.0.1",
    "@ld-v3-kit/components": "workspace:^",
    "@ld-v3-kit/composables": "workspace:^",
    "@ld-v3-kit/styles": "workspace:^",
    "@ld-v3-kit/utils": "workspace:^",
    "@pnpm/types": "^1101.2.0",
    "@types/eslint-config-prettier": "^6.11.3",
    "@types/node": "^25.9.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitejs/plugin-vue-jsx": "^5.1.5",
    "@vue/language-core": "^3.2.9",
    "@vue/tsconfig": "^0.9.1",
    "consola": "^3.4.2",
    "element-plus": "catalog:",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-vue": "^10.9.1",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jiti": "^2.7.0",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "rolldown": "^1.0.3",
    "rolldown-plugin-dts": "^0.25.2",
    "stylelint": "^17.12.0",
    "stylelint-config-html": "^1.1.0",
    "stylelint-config-recess-order": "^7.7.0",
    "stylelint-config-recommended-vue": "^1.6.1",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "tinyglobby": "^0.2.17",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "vue": "catalog:",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.2.9"
  },
  "config": {
    "commitizen": {
      "path": "@commitlint/cz-commitlint"
    }
  }
}
